#!/bin/bash

### To Run This Install Script, Do This Terminal Command:
# curl -sSL -H 'Cache-Control: no-cache, no-store' https://raw.githubusercontent.com/zerapix/public/main/bin/install | bash

############################################################################
# In General, this file will setup a machine.
# For now I only have it installing uv and zp, will do more in the future.
# ---------------------------------------------------------------------

# Ensure `uv` is installed
curl -LsSf https://astral.sh/uv/install.sh | sh

# Make sure directory exists
mkdir -p ~/.config/uv/

# Download `uv.toml` file and install
curl -sSL -H 'Cache-Control: no-cache, no-store' https://raw.githubusercontent.com/zerapix/public/main/uv.toml > ~/.config/uv/uv.toml

# `--index` should not be needed due to above `uv.toml` file, but including it here just in case (since this is a script and not a user typing it in).
uv tool install --index zp
